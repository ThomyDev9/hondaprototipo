# Stage 1: build
FROM node:18-alpine AS build
WORKDIR /app

# 👉 declarar la variable que viene de docker-compose
ARG VITE_API_BASE
ENV VITE_API_BASE=$VITE_API_BASE
ARG VITE_TICKET_API_URL
ENV VITE_TICKET_API_URL=$VITE_TICKET_API_URL
ARG VITE_MACHINE_CONTEXT_DIRECT_BASE
ENV VITE_MACHINE_CONTEXT_DIRECT_BASE=$VITE_MACHINE_CONTEXT_DIRECT_BASE
ARG VITE_MACHINE_CONTEXT_DIRECT_PORT
ENV VITE_MACHINE_CONTEXT_DIRECT_PORT=$VITE_MACHINE_CONTEXT_DIRECT_PORT
ARG VITE_INBOUND_ZOIPER_BYPASS_USERS
ENV VITE_INBOUND_ZOIPER_BYPASS_USERS=$VITE_INBOUND_ZOIPER_BYPASS_USERS

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# Stage 2: serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
